# gexbot configuration — copy to .env and fill in.
# tastytrade OAuth (same credentials the brokerage market-data feed uses).
TT_SECRET=your_tastytrade_provider_secret
TT_REFRESH=your_tastytrade_refresh_token

# Optional: where the live gamma snapshot is written/read. Default: <repo>/data
# GEXBOT_DATA_DIR=/var/lib/gexbot

# ── TV publisher (tv_publisher.py) ──────────────────────────────────────────
# The publisher pushes the GEX overlay onto the local TradingView Desktop chart
# by shelling out to the tradingview-mcp CLI over CDP (port 9222). It must run
# on the same machine as TradingView Desktop.
#
# Path to the tradingview-mcp CLI entry point.
# GEXBOT_TV_CLI=~/tradingview-mcp/src/cli/index.js
# node binary used to run the CLI.
# GEXBOT_TV_NODE=node
# Refresh cadence (seconds) during regular trading hours.
# GEXBOT_TV_REFRESH_SEC=30
# Where the generated Pine source is written. Default: <data>/gex_overlay.pine
# GEXBOT_PINE_OUT=/var/lib/gexbot/gex_overlay.pine
